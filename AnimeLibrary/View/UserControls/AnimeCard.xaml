<UserControl x:Class="AnimeLibrary.View.UserControls.AnimeCard"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:uc="clr-namespace:AnimeLibrary.View.UserControls"
             MinHeight="300" MinWidth="200"
             MaxHeight="450" MaxWidth="300">
    <Viewbox Stretch="Uniform">
        <Border Name="mainBorder" CornerRadius="20" MouseLeftButtonDown="Border_MouseLeftButtonDown" Cursor="Hand">
            <Border.Effect>
                <DropShadowEffect Color="Black" BlurRadius="10" ShadowDepth="0"/>
            </Border.Effect>
            <Border CornerRadius="20" Width="200" Height="300">
                <Border.Clip>
                    <RectangleGeometry RadiusX="10" RadiusY="10" Rect="0,0,200,300"/>
                </Border.Clip>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition/>
                        <RowDefinition Height="75"/>
                        <RowDefinition Height="50"/>
                    </Grid.RowDefinitions>
                    <Image Grid.Row="0" Grid.RowSpan="2" x:Name="animeImage" Stretch="UniformToFill"/>
                    <Border Grid.Row="0" Background="#4B0082" Width="30" Height="30"
                            HorizontalAlignment="Left" VerticalAlignment="Top"
                            Margin="10,10,0,0" CornerRadius="20">
                        <Border.Effect>
                            <DropShadowEffect Color="#4B0082" BlurRadius="10" ShadowDepth="0"/>
                        </Border.Effect>
                        <TextBlock Grid.Row="0" x:Name="animeScore" 
                               HorizontalAlignment="Center" VerticalAlignment="Center" 
                               FontSize="14" FontWeight="Bold" Foreground="White"/>
                    </Border>
                    <Grid Grid.Row="2">
                        <Grid.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#151515" Offset="0.00"/>
                                <GradientStop Color="#1D1D1D" Offset="0.20"/>
                                <GradientStop Color="#191919" Offset="0.40"/>
                                <GradientStop Color="#1F1B1F" Offset="0.59"/>
                                <GradientStop Color="#242124" Offset="0.79"/>
                                <GradientStop Color="#1E1E1E" Offset="1.00"/>
                            </LinearGradientBrush>
                        </Grid.Background>
                        <Grid.RowDefinitions>
                            <RowDefinition/>
                            <RowDefinition/>
                            <RowDefinition/>
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" x:Name="animeTitle" Foreground="#CED5D8" 
                                   FontSize="8" Margin="5,2,0,0" Text="Title"
                                   FontWeight="Bold"/>
                        <TextBlock Grid.Row="1" x:Name="animeAired" Foreground="#CED5D8" 
                                   FontSize="8" Margin="5,2,0,0" Text="Aired"
                                   FontWeight="Bold"/>
                        <TextBlock Grid.Row="2" x:Name="animeStudio" Foreground="#CED5D8" 
                                   FontSize="8" Margin="5,2,0,0" Text="Studio"
                                   FontWeight="Bold"/>
                    </Grid>
                    <Border Grid.RowSpan="2" Name="cardDim" Background="White" Opacity="0.05" Visibility="Collapsed"/>
                    <Grid Grid.Row="1">
                        <ScrollViewer Name="EpisodeScroll" VerticalScrollBarVisibility="Hidden" 
                                      HorizontalScrollBarVisibility="Disabled" Visibility="Collapsed"
                                      Background="Transparent">
                            <WrapPanel x:Name="EpisodeCards" Orientation="Horizontal" 
                                Margin="5,5,5,5" HorizontalAlignment="Left"
                                VerticalAlignment="Bottom">
                                <WrapPanel.Resources>
                                    <Style TargetType="uc:EpisodeCard">
                                        <Setter Property="Margin" Value="3,3,3,3"/>
                                    </Style>
                                </WrapPanel.Resources>
                            </WrapPanel>
                        </ScrollViewer>
                    </Grid>
                </Grid>
            </Border>
        </Border>
    </Viewbox>
</UserControl>