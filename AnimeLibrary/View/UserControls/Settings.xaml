<Window x:Class="AnimeLibrary.View.UserControls.Settings"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:AnimeLibrary.View.UserControls"
        mc:Ignorable="d" ResizeMode="NoResize" WindowStyle="None"
        Title="Settings" Height="500" Width="500" WindowStartupLocation="CenterOwner"
        AllowsTransparency="True" Background="Transparent">

    <!-- Styles -->
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/View/UserControls/ElementStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <Border CornerRadius="20" Margin="50" BorderThickness="1" BorderBrush="Purple">
        <Border.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1" Opacity="0.9">
                <GradientStop Color="#043639" Offset="0.00"/>
                <GradientStop Color="#0D1E3C" Offset="0.20"/>
                <GradientStop Color="#1A033F" Offset="0.40"/>
                <GradientStop Color="#2F0534" Offset="0.60"/>
                <GradientStop Color="#2D1749" Offset="0.80"/>
                <GradientStop Color="#152345" Offset="1.00"/>
            </LinearGradientBrush>
        </Border.Background>
        <Border.Effect>
            <DropShadowEffect Color="Black" BlurRadius="50" ShadowDepth="0"/>
        </Border.Effect>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="55"/>
                <RowDefinition Height="1"/>
                <RowDefinition/>
                <RowDefinition Height="50"/>
            </Grid.RowDefinitions>

            <!-- Title Bar -->
            <TextBlock Grid.Column="0" Text="🛠 Settings ⚙️" VerticalAlignment="Center" 
                HorizontalAlignment="Center" Grid.ColumnSpan="3"
                FontSize="14" Foreground="White"/>

            <Button x:Name="btnCloseS" Grid.Row="0" Content="&#xE8BB;" Width="35" Height="35"
                BorderBrush="Transparent" Background="Transparent"
                FontSize="15" HorizontalAlignment="Right" VerticalAlignment="Top"
                Margin="10"
                Click="btnCloseS_Click" FontFamily="Segoe MDL2 Assets"
                Style="{StaticResource ButtonHover}" Tag="25"/>

            <!-- Divider -->
            <Border Grid.Row="1" Height="1">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#0B4A4E" Offset="0.00"/>
                        <GradientStop Color="#173057" Offset="0.20"/>
                        <GradientStop Color="#2A0A5C" Offset="0.40"/>
                        <GradientStop Color="#47104E" Offset="0.59"/>
                        <GradientStop Color="#4A2A66" Offset="0.79"/>
                        <GradientStop Color="#243564" Offset="1.00"/>
                    </LinearGradientBrush>
                </Border.Background>
            </Border>


            <!-- Background -->
            <Border Grid.Row="2">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#02282B" Offset="0.00"/>
                        <GradientStop Color="#09152A" Offset="0.20"/>
                        <GradientStop Color="#12022E" Offset="0.40"/>
                        <GradientStop Color="#230228" Offset="0.59"/>
                        <GradientStop Color="#221238" Offset="0.79"/>
                        <GradientStop Color="#0E1A33" Offset="1.00"/>
                    </LinearGradientBrush>
                </Border.Background>
            </Border>
            <!-- Direcroty Text Block -->
            <TextBlock Grid.Row="2" Text="Video file directory"
                       Width="101" Height="17" Foreground="White"
                       HorizontalAlignment="Left" VerticalAlignment="Top"
                       Margin="20,20,0,0" FontSize="12"/>
            
            <!-- Directory Text Box -->
            <Border Grid.Row="2" CornerRadius="5"
                    Width="300" Height="25"
                    HorizontalAlignment="Left" VerticalAlignment="Top"
                    Margin="20,50,0,0" Background="#33808080">
                <TextBox x:Name="txtDirectory" Background="Transparent"
                         BorderThickness="0" Foreground="White"
                         VerticalContentAlignment="Center" HorizontalAlignment="Left"
                         Margin="5,0,5,0" Height="20" Width="270"/>
            </Border>
            
            <!-- Directory Browse Button -->
            <Button Grid.Row="2" x:Name="btnBrowse" Content="📁" Width="25" Height="25"
                BorderBrush="Transparent" Background="Transparent"
                FontSize="12" HorizontalAlignment="Right" VerticalAlignment="Top"
                Margin="0,50,78,0"
                Click="btnBrowse_Click" FontFamily="Segoe UI Emoji"
                Style="{StaticResource ButtonHover}" Tag="5"/>
            
            <!-- Save to Config Checkbox -->
            <CheckBox Grid.Row="2" x:Name="chkSaveConfig" Content="Save to config file" 
                      Foreground="White" HorizontalAlignment="Left" VerticalAlignment="Top" 
                      Margin="20,90,0,0" Background="#33808080"
                      Style="{StaticResource CheckHover}" Checked="chkSaveConfig_Checked"/>

            <!-- Save to Config Checkbox -->
            <CheckBox Grid.Row="2" x:Name="chkResetConfig" Content="Reset config file" 
                      Foreground="White" HorizontalAlignment="Left" VerticalAlignment="Top" 
                      Margin="20,125,0,0" Background="#33808080"
                      Style="{StaticResource CheckHover}" Checked="chkResetConfig_Checked"/>

            <!-- Confirm Button -->
            <Button x:Name="btnConfirm" Grid.Row="3" Content="✔️" Width="40" Height="40"
                BorderBrush="Transparent" Background="Transparent"
                FontSize="25" HorizontalAlignment="Center" VerticalAlignment="Center"
                Click="btnConfirm_Click"
                Style="{StaticResource ButtonHover}" Tag="2"/>
        </Grid>
    </Border>

</Window>
