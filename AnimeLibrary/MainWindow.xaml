<Window x:Class="AnimeLibrary.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:AnimeLibrary"
        xmlns:svg="http://sharpvectors.codeplex.com/svgc/"
        xmlns:uc="clr-namespace:AnimeLibrary.View.UserControls"
        mc:Ignorable="d" WindowStyle="None"
        Title="Anime Library"
        MinHeight="800" MinWidth="1325"
        Height="800" Width="1325" Icon="pack://application:,,,/View/Assets/icon.ico">
    <WindowChrome.WindowChrome>
        <WindowChrome GlassFrameThickness="0" CornerRadius="0" CaptionHeight="0"/>
    </WindowChrome.WindowChrome>

    <!-- Styles -->
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/View/UserControls/ElementStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <!-- Main -->
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="35"/>
            <RowDefinition Height="1"/>
            <RowDefinition/>
        </Grid.RowDefinitions>

        <!-- Title Bar -->
        <Grid Grid.Row="0" MouseDown="Grid_MouseDown">
            <Grid.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#043639" Offset="0.00"/>
                    <GradientStop Color="#0D1E3C" Offset="0.20"/>
                    <GradientStop Color="#1A033F" Offset="0.40"/>
                    <GradientStop Color="#2F0534" Offset="0.59"/>
                    <GradientStop Color="#2D1749" Offset="0.79"/>
                    <GradientStop Color="#152345" Offset="1.00"/>
                </LinearGradientBrush>
            </Grid.Background>

            <Grid.ColumnDefinitions>
                <ColumnDefinition/>
                <ColumnDefinition Width="165"/>
            </Grid.ColumnDefinitions>

            <TextBlock Text="🌸 Anime Library 📚" VerticalAlignment="Center" 
               HorizontalAlignment="Center" Grid.ColumnSpan="3"
               FontSize="14" Foreground="White" Height="19" Width="130"/>

            <!--> Window Control Buttons -->
            <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center" Height="35" Width="162">
                <Button Grid.Column="1" x:Name="btnSettings" Content="🛠" Width="35" Height="35"
                    BorderBrush="Transparent" Background="Transparent"
                    FontSize="12"
                    Click="btnSettings_Click" FontFamily="Segoe UI Emoji"
                    Style="{StaticResource ButtonHover}" Tag="0"
                    Margin="0,0,10,0"/>
                <Border Grid.Column="2" Width="1" Height="15" Background="Gray"
                        Margin="0,0,10,0"/>
                <Button x:Name="btnMinW" Content="&#xE921;" Width="35" Height="35"
                        BorderBrush="Transparent" Background="Transparent"
                        FontSize="10"
                        Click="btnMinW_Click" FontFamily="Segoe MDL2 Assets"
                        Style="{StaticResource ButtonHover}" Tag="0"/>
                <Button x:Name="btnMaxW" Content="&#xE922;" Width="35" Height="35"
                        BorderBrush="Transparent" Background="Transparent"
                        FontSize="10"
                        Click="btnMaxW_Click" FontFamily="Segoe MDL2 Assets"
                        Style="{StaticResource ButtonHover}" Tag="0"/>
                <Button x:Name="btnCloseW" Content="&#xE8BB;" Width="35" Height="35"
                        BorderBrush="Transparent" Background="Transparent"
                        FontSize="10"
                        Click="btnCloseW_Click" FontFamily="Segoe MDL2 Assets"
                        Style="{StaticResource ButtonHover}" Tag="0"/>
            </StackPanel>
        </Grid>

        <!-- Divider -->
        <Border Grid.Row="1" Height="1">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#0B4A4E" Offset="0.00"/>
                    <GradientStop Color="#173057" Offset="0.20"/>
                    <GradientStop Color="#2A0A5C" Offset="0.40"/>
                    <GradientStop Color="#47104E" Offset="0.59"/>
                    <GradientStop Color="#4A2A66" Offset="0.79"/>
                    <GradientStop Color="#243564" Offset="1.00"/>
                </LinearGradientBrush>
            </Border.Background>
        </Border>

        <!--> Content -->
        <Grid Grid.Row="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="50"/>
                <RowDefinition/>
            </Grid.RowDefinitions>
            <Grid.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#02282B" Offset="0.00"/>
                    <GradientStop Color="#09152A" Offset="0.20"/>
                    <GradientStop Color="#12022E" Offset="0.40"/>
                    <GradientStop Color="#230228" Offset="0.59"/>
                    <GradientStop Color="#221238" Offset="0.79"/>
                    <GradientStop Color="#0E1A33" Offset="1.00"/>
                </LinearGradientBrush>
            </Grid.Background>
            <!-- Search Bar -->
            <uc:SearchTextBox x:Name="tbSearch" PlaceHolder="Search..." Width="200" 
                              Visibility="Collapsed"/>
            
            <!-- Clear Cards Button -->
            <Button x:Name="btnClearCards" Width="30" Height="30" Background="Transparent" BorderThickness="0"
                    Foreground="White" FontSize="18" VerticalContentAlignment="Center"
                    Margin="0,0,235,0" Style="{StaticResource TrashButtonHover}"
                    MouseEnter="btnClearCards_MouseEnter" MouseLeave="btnClearCards_MouseLeave"
                    Click="btnClearCards_Click" Visibility="Collapsed">
                <svg:SvgViewbox Source="pack://application:,,,/View/Assets/bin.svg" Stretch="Uniform"
                                    Width="20" Height="20" HorizontalAlignment="Center" 
                                    VerticalAlignment="Center"/>
            </Button>
            
            <!-- Clear Cards Button Hover Information -->
            <StackPanel x:Name="TrashHoverInfo" Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Center"
                        Margin="0,0,350,0" Visibility="Collapsed">
                <!-- TextBlock -->
                <Border Background="#25FFFFFF" Padding="3" CornerRadius="5">
                    <TextBlock Text="Clear Cards" Foreground="White"/>
                </Border>

                <!-- Arrow pointing right -->
                <Polygon Points="0,0 5,5 0,10"
                        Fill="#25FFFFFF"
                        VerticalAlignment="Center"/>
            </StackPanel>
            
            <!-- Anime Cards -->
            <ScrollViewer x:Name="cardScroll" Grid.Row="1" VerticalScrollBarVisibility="Hidden" HorizontalScrollBarVisibility="Disabled">
                <WrapPanel x:Name="AnimeCards" Orientation="Horizontal" 
                        Margin="50,0,50,50" HorizontalAlignment="Left"
                        VerticalAlignment="Top">
                    <WrapPanel.Resources>
                        <Style TargetType="uc:AnimeCard">
                            <Setter Property="Margin" Value="5,0,0,0"/>
                        </Style>
                    </WrapPanel.Resources>
                </WrapPanel>
            </ScrollViewer>
        </Grid>
        <Border Grid.ColumnSpan="2" Grid.RowSpan="3" Name="windowDim" Background="Black" Opacity="0.5" Visibility="Collapsed"/>
    </Grid>
</Window>